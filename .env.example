# Scrumban-Backend-V2 — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite .env.

# ─── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug

# ─── Database (Postgres) ──────────────────────────────────────────────
POSTGRES_USER=scrumban
POSTGRES_PASSWORD=scrumban_dev_2026
POSTGRES_DB=scrumban_v2
POSTGRES_PORT=5433
DATABASE_URL=postgresql://scrumban:scrumban_dev_2026@localhost:5433/scrumban_v2?schema=public

# ─── Redis (Cache + BullMQ) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ─── Auth (JWT) ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bit-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ALGORITHM=HS256

# ─── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ─── Timezone ─────────────────────────────────────────────────────────
TZ=America/Sao_Paulo

# ─── Feature Flags (opt-in modules) ───────────────────────────────────
TELEGRAM_ENABLED=false
MCP_ENABLED=false
WEBHOOKS_ENABLED=true
AUTOMATION_ENABLED=false
EMAIL_ENABLED=false

# ─── Telegram (F10) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── Groq Whisper (voz — F10) ─────────────────────────────────────────
GROQ_API_KEY=

# ─── MCP Server (F11) ─────────────────────────────────────────────────
MCP_RATE_LIMIT_PER_MINUTE=60

# ─── Webhooks outbound (F12) ──────────────────────────────────────────
WEBHOOK_RETRY_MAX=3
WEBHOOK_FAILURE_THRESHOLD=10

# ─── Automation Claude Code (F13) ─────────────────────────────────────
AUTOMATION_INSTALL_TOKEN_TTL_MIN=10
AUTOMATION_HEARTBEAT_INTERVAL_SEC=30
AUTOMATION_HEARTBEAT_OFFLINE_AFTER_SEC=90
STRICT_RISK_GATE=true
GITHUB_API_TOKEN=

# ─── Email (F4) ───────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@scrumban.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Database Logging (debug N+1) ─────────────────────────────────────
DATABASE_LOGGING=false
